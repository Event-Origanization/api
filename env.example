# Server Configuration
NODE_ENV=development
PORT=8000
HOST=localhost

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=pevent_db
DB_USER=pevent_admin
DB_PASSWORD=MySQL1998
DB_ROOT_PASSWORD=MySQL1998

# JWT Configuration
JWT_ACCESS_SECRET=access_key
JWT_REFRESH_SECRET=refresh_key
JWT_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=12h
JWT_ALGORITHM=HS256

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=cloud_name
CLOUDINARY_API_KEY=api_key
CLOUDINARY_API_SECRET=secret_key

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=airemakepro@gmail.com
EMAIL_PASS=key

# ACCOUNT SUPPER ADMIN
USERNAME=SUPPER_ADMIN
EMAIL_ADMIN=example@gmail.com
PASSWORD_ADMIN=example

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3001,http://localhost:3000,http://localhost:5173,https://event-omega-three.vercel.app/

# API Configuration
API_VERSION=/v1
API_PREFIX=/api 

# FE URL
FRONTEND_URL=http://localhost:3000

# Image Optimization (Cloudinary URL transform)
# Bật/tắt tối ưu ảnh ở tầng middleware (true/false). Mặc định bật nếu không đặt false
IMAGE_OPTIMIZE_ENABLED=true
# Chiều rộng mặc định nếu không có Client Hints/qs (ví dụ desktop)
IMAGE_OPTIMIZE_DEFAULT_W=800
# Chiều cao mặc định (tùy chọn). Để trống hoặc 0 để bỏ qua
IMAGE_OPTIMIZE_DEFAULT_H=0
# Giới hạn tối đa chiều rộng/chiều cao khi đọc từ header/query client
IMAGE_OPTIMIZE_MAX_W=1600
IMAGE_OPTIMIZE_MAX_H=1200

# Translation Service
GOOGLE_TRANSLATE_URL=https://translate.googleapis.com/translate_a/single

GEMINI_API_KEY=example-key
GEMINI_MODEL=gemini-2.5-flash-lite
